SELECT ?item ?itemLabel (MIN(?yearValue) AS ?year) (SAMPLE(?locationName) AS ?locationLabel) (SAMPLE(?descriptionText) AS ?description) ?sitelinks WHERE {
  ?item
    wdt:P31/wdt:P279* wd:Q33506; # instance of or subclass of "museum"
    wikibase:sitelinks ?sitelinks; # use sitelinks as a rough popularity signal
    rdfs:label ?itemLabel.
  FILTER(LANG(?itemLabel) = "en")
  OPTIONAL {
    ?item schema:description ?descriptionText.
    FILTER(LANG(?descriptionText) = "en")
  }
  OPTIONAL {
    ?item wdt:P131 ?location.
    ?location rdfs:label ?locationName.
    FILTER(LANG(?locationName) = "en")
  }
  ?item wdt:P1619 ?date. # official opening date
  FILTER(YEAR(?date) > 1000)
  FILTER(?sitelinks >= 30) # cut off very obscure entries
  BIND(YEAR(?date) AS ?yearValue) # turn the chosen date into a timeline year
}
GROUP BY ?item ?itemLabel ?sitelinks # collapse duplicates caused by optional joins or multiple dates
ORDER BY DESC(?sitelinks) # keep the most recognisable rows first
LIMIT 500
