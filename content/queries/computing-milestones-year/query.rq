SELECT ?item ?itemLabel (MIN(?yearValue) AS ?year) (SAMPLE(?inventorName) AS ?inventorLabel) ?sitelinks WHERE {
  VALUES ?itemLabel { # hand-picked labels for this pack
    "computer"@en
    "Atanasoff–Berry Computer"@en
    "computer mouse"@en
    "Darlington transistor"@en
    "mechanical computer"@en
    "Pascal's calculator"@en
    "Electronic Delay Storage Automatic Calculator"@en
  }

  ?item
    rdfs:label ?itemLabel;
    wdt:P61 ?inventor;
    wikibase:sitelinks ?sitelinks. # use sitelinks as a rough popularity signal

  ?inventor wdt:P31 wd:Q5. # only keep people

  OPTIONAL {
    ?item wdt:P575 ?datedAt.
  }
  OPTIONAL {
    ?item wdt:P571 ?inception.
  }
  OPTIONAL {
    ?inventor rdfs:label ?inventorName.
    FILTER(LANG(?inventorName) = "en")
  }

  BIND(COALESCE(?datedAt, ?inception) AS ?date) # take the first date that exists
  FILTER(BOUND(?date)) # skip rows with no usable date
  BIND(YEAR(?date) AS ?yearValue) # turn the chosen date into a timeline year
}
GROUP BY ?item ?itemLabel ?sitelinks # collapse duplicates caused by optional joins or multiple dates
ORDER BY DESC(?sitelinks) # keep the most recognisable rows first


