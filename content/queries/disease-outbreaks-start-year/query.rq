SELECT ?item ?itemLabel (MIN(?yearValue) AS ?year) ?sitelinks WHERE {
  ?item
    wdt:P31/wdt:P279* wd:Q3241045; # instance of or subclass of "disease outbreak"
    wdt:P580 ?date; # use the start date
    wikibase:sitelinks ?sitelinks; # use sitelinks as a rough popularity signal
    rdfs:label ?itemLabel.
  FILTER(LANG(?itemLabel) = "en")
  FILTER(LCASE(STR(?itemLabel)) != "hiv/aids")
  FILTER(!CONTAINS(LCASE(STR(?itemLabel)), " in "))
  FILTER(!CONTAINS(LCASE(STR(?itemLabel)), " on "))
  FILTER(!CONTAINS(LCASE(STR(?itemLabel)), " season"))
  FILTER(!REGEX(STR(?itemLabel), "^COVID-19 pandemic in ", "i"))
  FILTER(!EXISTS { ?item wdt:P17 ?country. })
  BIND(YEAR(?date) AS ?yearValue) # turn the chosen date into a timeline year
}
GROUP BY ?item ?itemLabel ?sitelinks # collapse duplicates caused by optional joins or multiple dates
ORDER BY DESC(?sitelinks) # keep the most recognisable rows first
LIMIT 500


