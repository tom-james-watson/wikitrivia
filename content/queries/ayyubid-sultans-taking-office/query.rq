SELECT DISTINCT ?item ?itemLabel ?positionLabel ?sexLabel ?year ?sitelinks WHERE {
  VALUES ?position { wd:Q4115925 }
  ?item
    wdt:P31 wd:Q5;
    p:P39 ?statement;
    wikibase:sitelinks ?sitelinks;
    rdfs:label ?itemLabel.
  ?statement
    ps:P39 ?position;
    pq:P580 ?date.
  FILTER NOT EXISTS {
    ?item p:P39 ?earlierStatement.
    ?earlierStatement
      ps:P39 ?position;
      pq:P580 ?earlierDate.
    FILTER(?earlierDate < ?date)
  }
  OPTIONAL {
    ?item wdt:P21 ?sex. # use sex or gender for gender-aware leader titles when available
    ?sex rdfs:label ?sexLabel.
    FILTER(LANG(?sexLabel) = "en")
  }
  FILTER(LANG(?itemLabel) = "en")
  FILTER(?sitelinks >= 5)
  BIND(YEAR(?date) AS ?year)
  FILTER(?year >= 1169 && ?year < 1250)
  BIND("Ayyubid sultan"@en AS ?positionLabel)
}
ORDER BY DESC(?sitelinks)
LIMIT 40
