{
  "name": "wikitrivia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "agent:check": "bun run typecheck && bun run lint && bun run format",
    "format": "oxfmt --config .oxfmtrc.json --ignore-path .gitignore --ignore-path .oxfmtignore --write .",
    "format:check": "oxfmt --config .oxfmtrc.json --ignore-path .gitignore --ignore-path .oxfmtignore --check .",
    "lint": "tsc && oxlint --config .oxlintrc.json .",
    "lint-fix": "oxlint --config .oxlintrc.json --fix .",
    "test": "bun test",
    "typecheck": "tsc",
    "decks:tree": "bun run content/scripts/print-deck-tree.ts",
    "decks:build": "bun run content/scripts/build-cards.ts",
    "sparql:list": "bun run content/scripts/run-sparql.ts --list",
    "sparql:run": "bun run content/scripts/run-sparql.ts",
    "start": "serve out"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-github-btn": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-no-ssr": "^1.1.8",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/next-plugin": "^2.5.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/sprinkles": "^1.6.5",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "serve": "^14.2.6",
    "typescript": "^5.9.3"
  }
}
